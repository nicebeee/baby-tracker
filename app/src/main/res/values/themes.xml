<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Светлая тема -->
    <style name="Theme.BabyTracker" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_blue_light</item>
        <item name="colorOnPrimaryContainer">@color/brand_blue_dark</item>
        <item name="colorSecondary">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorOnBackground">@color/on_surface_light</item>
        <item name="android:textColor">@color/on_surface_light</item>
        <item name="android:textColorHint">@color/on_surface_secondary_light</item>
        <item name="bottomNavigationStyle">@style/Widget.BabyTracker.BottomNavigation</item>
    </style>

    <!-- Тёмная тема -->
    <style name="Theme.BabyTracker.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_blue_light</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/brand_blue_dark</item>
        <item name="colorOnPrimaryContainer">@color/brand_blue_light</item>
        <item name="colorSecondary">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/on_surface_dark</item>
        <item name="android:textColor">@color/on_surface_dark</item>
        <item name="android:textColorHint">@color/on_surface_secondary_dark</item>
        <item name="bottomNavigationStyle">@style/Widget.BabyTracker.BottomNavigation</item>
    </style>

    <!-- Bottom nav — всегда показывает подписи -->
    <style name="Widget.BabyTracker.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- Стиль для диалогов — явный белый/тёмный фон -->
    <style name="Theme.BabyTracker.Dialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

</resources>
